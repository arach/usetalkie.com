# Dependencies
node_modules
out

# Logs
*.log
logs/

# Local specs (brand docs, review scaffolding, scratch briefs)
# Kept on disk for working reference but never tracked.
*/specs/

# === Dotfile allowlist policy ===
# Ignore all dotfiles by default. New dotfiles (.env*, .tmp-*, .next,
# .DS_Store, AI tooling state like .claude/ and .openscout/, editor
# configs, .vercel, .devmux.json, etc.) stay OUT of git unless they
# appear in the allowlist below. Add exceptions deliberately and
# review them in code review.
.*
!.gitignore
!.github/
!.gitkeep
# OpenScout local state
.openscout/project.json
